{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "github>rhapsodic-dev/renovate-config"
  ],
  "packageRules": [
    {
      "enabled": false,
      "matchDepTypes": [
        "peerDependencies"
      ]
    },
    {
      "enabled": false,
      "matchDepTypes": [
        "engines"
      ],
      "matchManagers": [
        "npm"
      ],
      "matchPackageNames": [
        "node"
      ]
    }
  ]
}
