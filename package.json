{
  "name": "@rhapsodic/eslint-config",
  "type": "module",
  "version": "1.0.5",
  "packageManager": "pnpm@11.3.0+sha512.2c403d6594527287672b1f7056343a1f7c3634036a67ffabfcc2b3d7595d843768f8787148d1b57cf7956c90606bbd192857c363af19e96d2d0ec9ec5741d215",
  "description": "Rhapsodic's ESLint config",
  "author": "Svyatoslav Fyodorov <intelrug@gmail.com> (https://github.com/intelrug/)",
  "license": "MIT",
  "homepage": "https://github.com/rhapsodic-dev/eslint-config",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rhapsodic-dev/eslint-config.git"
  },
  "bugs": {
    "url": "https://github.com/rhapsodic-dev/eslint-config/issues"
  },
  "keywords": [
    "eslint-config"
  ],
  "exports": {
    ".": "./dist/index.mjs"
  },
  "main": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "files": [
    "bin",
    "dist"
  ],
  "scripts": {
    "build": "nr gen && tsdown --clean --dts",
    "stub": "tsdown",
    "dev": "npx @eslint/config-inspector --config eslint.config.ts",
    "build:inspector": "pnpm build && npx @eslint/config-inspector build",
    "watch": "tsdown --watch",
    "lint": "eslint",
    "format": "eslint --fix",
    "gen": "tsx scripts/typegen.ts",
    "prepack": "nr build",
    "release": "bumpp",
    "test": "vitest",
    "typecheck": "tsc --noEmit",
    "prepare": "simple-git-hooks"
  },
  "peerDependencies": {
    "eslint": "^9.35.0 || ^10.0.0",
    "eslint-plugin-vuejs-accessibility": "^2.4.1",
    "vue": "^3.0.0"
  },
  "peerDependenciesMeta": {
    "eslint-plugin-vuejs-accessibility": {
      "optional": true
    },
    "vue": {
      "optional": true
    }
  },
  "dependencies": {
    "@antfu/install-pkg": "^1.1.0",
    "@clack/prompts": "^1.4.0",
    "@stylistic/eslint-plugin": "^5.10.0",
    "@typescript-eslint/eslint-plugin": "^8.60.0",
    "@typescript-eslint/parser": "^8.60.0",
    "eslint-flat-config-utils": "^3.2.0",
    "eslint-merge-processors": "^2.0.0",
    "eslint-plugin-import-x": "^4.16.2",
    "eslint-plugin-unicorn": "^64.0.0",
    "eslint-plugin-vue": "^10.9.1",
    "eslint-processor-vue-blocks": "^2.0.0",
    "globals": "^17.6.0",
    "local-pkg": "^1.2.1",
    "vue-eslint-parser": "^10.4.0"
  },
  "devDependencies": {
    "@rhapsodic/eslint-config": "workspace:*",
    "@antfu/ni": "^30.1.0",
    "@eslint/config-inspector": "^3.0.3",
    "@types/node": "^24.12.4",
    "bumpp": "^11.1.0",
    "eslint": "^10.4.0",
    "eslint-plugin-vuejs-accessibility": "^2.5.0",
    "eslint-typegen": "^2.3.1",
    "execa": "^9.6.1",
    "lint-staged": "^17.0.5",
    "pnpm-workspace-yaml": "^1.6.1",
    "simple-git-hooks": "^2.13.1",
    "tinyglobby": "^0.2.16",
    "tsdown": "^0.22.0",
    "tsx": "^4.22.3",
    "typescript": "^6.0.3",
    "vitest": "^4.1.7",
    "vue": "^3.5.35"
  },
  "simple-git-hooks": {
    "pre-commit": "npx lint-staged"
  },
  "lint-staged": {
    "*": "eslint --fix"
  }
}
