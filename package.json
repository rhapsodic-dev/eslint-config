{
  "name": "@rhapsodic/eslint-config",
  "type": "module",
  "version": "1.1.0",
  "packageManager": "pnpm@11.9.0+sha512.bd682d5d03fe525ef7c9fd6780c6884d1e756ac4c9c9fe00c538782824310dcf90e3ddc4f53835f06dfaebd5085e41855e0bcbb3b60de2ac5bbab89e5036f03b",
  "description": "Rhapsodic's ESLint config",
  "author": "Svyatoslav Fyodorov <intelrug@gmail.com> (https://github.com/intelrug/)",
  "license": "MIT",
  "homepage": "https://github.com/rhapsodic-dev/eslint-config",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rhapsodic-dev/eslint-config.git"
  },
  "bugs": {
    "url": "https://github.com/rhapsodic-dev/eslint-config/issues"
  },
  "keywords": [
    "eslint-config"
  ],
  "exports": {
    ".": "./dist/index.mjs"
  },
  "main": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "files": [
    "bin",
    "dist"
  ],
  "scripts": {
    "build": "nr gen && tsdown --clean --dts",
    "stub": "tsdown",
    "dev": "npx @eslint/config-inspector --config eslint.config.ts",
    "build:inspector": "pnpm build && npx @eslint/config-inspector build",
    "watch": "tsdown --watch",
    "lint": "eslint",
    "format": "eslint --fix",
    "gen": "tsx scripts/typegen.ts",
    "prepack": "nr build",
    "release": "bumpp",
    "test": "vitest",
    "typecheck": "tsc --noEmit",
    "prepare": "simple-git-hooks"
  },
  "peerDependencies": {
    "eslint": "^9.35.0 || ^10.0.0",
    "eslint-plugin-vuejs-accessibility": "^2.4.1",
    "vue": "^3.0.0"
  },
  "peerDependenciesMeta": {
    "eslint-plugin-vuejs-accessibility": {
      "optional": true
    },
    "vue": {
      "optional": true
    }
  },
  "dependencies": {
    "@antfu/install-pkg": "^1.1.0",
    "@clack/prompts": "^1.6.0",
    "@stylistic/eslint-plugin": "^5.10.0",
    "@typescript-eslint/eslint-plugin": "^8.62.0",
    "@typescript-eslint/parser": "^8.62.0",
    "eslint-flat-config-utils": "^3.2.0",
    "eslint-merge-processors": "^2.0.0",
    "eslint-plugin-import-x": "^4.17.1",
    "eslint-plugin-unicorn": "^69.0.0",
    "eslint-plugin-vue": "^10.9.2",
    "eslint-processor-vue-blocks": "^2.0.0",
    "globals": "^17.7.0",
    "local-pkg": "^1.2.1",
    "vue-eslint-parser": "^10.4.1"
  },
  "devDependencies": {
    "@rhapsodic/eslint-config": "workspace:*",
    "@antfu/ni": "^30.2.0",
    "@eslint/config-inspector": "^3.0.4",
    "@types/node": "^24.13.2",
    "bumpp": "^11.1.0",
    "eslint": "^10.6.0",
    "eslint-plugin-vuejs-accessibility": "^2.5.0",
    "eslint-typegen": "^2.3.1",
    "execa": "^9.6.1",
    "lint-staged": "^17.0.8",
    "pnpm-workspace-yaml": "^1.6.1",
    "simple-git-hooks": "^2.13.1",
    "tinyglobby": "^0.2.17",
    "tsdown": "^0.22.3",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9",
    "vue": "^3.5.39"
  },
  "simple-git-hooks": {
    "pre-commit": "npx lint-staged"
  },
  "lint-staged": {
    "*": "eslint --fix"
  }
}
